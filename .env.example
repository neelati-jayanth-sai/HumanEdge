# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Gesture backend ────────────────────────────────────────────────────────────
# "mediapipe"  — built-in GestureRecognizer + ASL rule classifier (default, no training needed)
# "pytorch"    — custom trained GestureNet .pt model (requires GESTURE_MODEL_PATH)
GESTURE_BACKEND=mediapipe

# Path to trained GestureNet weights (only required when GESTURE_BACKEND=pytorch)
# GESTURE_MODEL_PATH=backend/models/gesture_net.pt

# ── Frame limits ───────────────────────────────────────────────────────────────
MAX_FRAME_BYTES=300000
MAX_FRAME_WIDTH=1280
MAX_FRAME_HEIGHT=720
MAX_FPS=15

# ── Gesture stability ──────────────────────────────────────────────────────────
# How long (ms) a gesture must be held before it commits as a token.
# Adaptive windowing reduces this for high-confidence detections.
STABLE_WINDOW_MS=200

# ── Confidence thresholds ──────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
MEDIAPIPE_CONFIDENCE_THRESHOLD=0.35
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

# ── MediaPipe options ──────────────────────────────────────────────────────────
MEDIAPIPE_STATIC_IMAGE_MODE=true
MEDIAPIPE_TRY_FLIPPED_FRAME=true

# ── Debug ──────────────────────────────────────────────────────────────────────
EMIT_DEBUG_FRAMES=true

# ── LLM context ───────────────────────────────────────────────────────────────
CONVERSATION_CONTEXT_TURNS=6

# ── Frontend (Next.js) — only needed if backend is on a different host ─────────
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# NEXT_PUBLIC_API_URL=http://localhost:8000
